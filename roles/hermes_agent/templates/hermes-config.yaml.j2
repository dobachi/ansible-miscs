# Hermes Agent 設定 (config v27+ / Hermes 0.18.x 想定)
# Managed by Ansible role hermes_agent.
#
# 既定では initial bootstrap only (`force: false` 相当)。
# `hermes setup` / `hermes model` / `hermes config set` で加えた修正は
# 再 ansible 実行で上書きされない。テンプレ変更を強制反映したいときは
# `-e hermes_agent_reset_config=true` を渡す。
#
# OpenRouter primary:
#   - provider: openrouter は Hermes の HermesOverlay に登録済み
#     (hermes_cli/providers.py:47) なので、base_url を config に書く必要なし。
#   - 認証は OPENROUTER_API_KEY (~/.hermes/.env) 側で渡す。
#
# terminal.cwd:
#   - dashboard / messaging 起動のセッションが初期に居るディレクトリ。
#   - CLI 経由 (docker exec) は docker run の WORKDIR がそのまま効くので不要だが、
#     dashboard 起動セッションは gateway が terminal.cwd を参照するので明示する。

model:
  provider: openrouter
  default: {{ hermes_agent_openrouter_model }}
{% if hermes_agent_terminal_cwd | length > 0 %}
terminal:
  cwd: {{ hermes_agent_terminal_cwd }}
{% endif %}
