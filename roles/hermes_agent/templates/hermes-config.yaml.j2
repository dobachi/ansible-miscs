# Hermes Agent 設定 (config v27 / Hermes 0.16.0 想定)
# Managed by Ansible role hermes_agent.
#
# 既定では initial bootstrap only (`force: false` 相当)。Hermes CLI
# (`hermes setup` / `hermes model`) や手書きで加えた修正は再 ansible 実行で
# 上書きされない。テンプレ変更を強制反映したいときは
# `-e hermes_agent_reset_config=true` を渡す。
#
# v27 schema 観察結果 (2026-06):
#   - 主脳の provider 情報 (base_url / api_key / api_mode) は `model:` ブロック
#     に **直接** 書く。`model.provider: custom` だけだと OpenRouter
#     (custom のデフォルト) にフォールバックして HTTP 400 になる
#   - `api_mode: chat_completions` を明示しないと auto-detect が
#     llama-server の `/v1/models` レスポンスに含まれる Ollama 互換フィールド
#     を見て Ollama 判定 → `/api/chat` を叩いて HTTP 405 になる
#   - Hermes Agent は最低 64K context を要求する。Qwen2.5-Coder の
#     n_ctx_train は 32768 なので、llama-server 側で --ctx-size 65536 に
#     RoPE 延長し、ここでも context_length を明示しておく必要がある
#
# 副 provider (Claude や OpenRouter など) を併用する場合は ansible 実行後に
# `hermes setup` / `hermes model` で追加登録すると custom_providers セクションに
# 書かれる。ロールはここを生成しないので CLI 側の編集を尊重する。

model:
  provider: custom
  default: {{ hermes_agent_local_model_name }}
  base_url: {{ hermes_agent_local_base_url }}
  api_key: {{ hermes_agent_local_api_key }}
  api_mode: {{ hermes_agent_local_api_mode }}
  context_length: {{ hermes_agent_local_context_length }}
