# /etc/hermes-gateway.env — Hermes Agent gateway container secrets
# Managed by Ansible role hermes_agent. Do not hand-edit.
#
# hermes-gateway.service が `docker run --env-file` で読み込む。
# ここに secrets を集約することで:
#   - unit file (mode 0644) や `systemctl show` からパスワードが漏れない
#   - `ps auxf` の docker CLI args にも表れない (--env-file はパスのみ)
# ファイル自体は 0600 / root:root で root しか読めない。

{% if hermes_agent_dashboard_enable | bool and hermes_agent_dashboard_basic_auth_username | length > 0 %}
HERMES_DASHBOARD_BASIC_AUTH_USERNAME={{ hermes_agent_dashboard_basic_auth_username }}
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD={{ hermes_agent_dashboard_basic_auth_password }}
{% endif %}
{% if hermes_agent_api_server_enable | bool %}
API_SERVER_KEY={{ hermes_agent_api_server_key }}
{% endif %}
