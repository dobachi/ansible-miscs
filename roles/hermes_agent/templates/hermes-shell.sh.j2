#!/usr/bin/env bash
# {{ hermes_agent_shell_helper_name }} — Hermes Agent gateway container の bash に潜る helper
# Managed by Ansible role hermes_agent. Do not hand-edit.
#
# 使い方:
#   {{ hermes_agent_shell_helper_name }}          gateway container 内で bash を開く
#   {{ hermes_agent_shell_helper_name }} -c "ls"  bash -c 経由で 1 コマンド
#
# gateway 中の hermes user (UID/GID は host と同じ) で入るので、workspace
# 配下に書き込んだファイルは host 側でもそのまま dobachi 所有になる。
# 常駐 curator / dashboard 等の稼働状態を眺めるのに使う。
#
# 事前に systemd unit で常駐 container が起動している必要がある:
#   sudo systemctl start {{ hermes_agent_systemd_unit_name }}

set -euo pipefail

CONTAINER_NAME="${HERMES_CONTAINER:-{{ hermes_agent_container_name }}}"

_ps_out="$(docker ps --filter "name=^${CONTAINER_NAME}$" --format '{{ "{{" }}.Names{{ "}}" }}' 2>&1)"
_ps_rc=$?
if [[ $_ps_rc -ne 0 ]]; then
  if [[ "$_ps_out" == *"permission denied"* ]]; then
    echo "error: current shell cannot talk to Docker daemon (permission denied on docker.sock)" >&2
    echo "fix  : 'newgrp docker' in this terminal, or fully log out and log back in." >&2
    exit 2
  fi
  echo "error: 'docker ps' failed:" >&2
  echo "$_ps_out" >&2
  exit $_ps_rc
fi
if ! grep -qx "${CONTAINER_NAME}" <<<"$_ps_out"; then
  echo "error: gateway container '${CONTAINER_NAME}' is not running" >&2
  echo "hint: sudo systemctl start {{ hermes_agent_systemd_unit_name }}" >&2
  exit 1
fi

if [[ -t 0 && -t 1 ]]; then
  DOCKER_TTY_FLAGS=(-it)
else
  DOCKER_TTY_FLAGS=(-i)
fi

exec docker exec "${DOCKER_TTY_FLAGS[@]}" \
  -u hermes \
  -w /opt/data/workspace \
  "${CONTAINER_NAME}" \
  bash "$@"
