{{ ansible_managed | comment }}
{% if gnome_terminal_tab_switch_apply_gnome_terminal %}
[org/gnome/terminal/legacy/keybindings]
# Master switch for the legacy keybindings schema. Without this, custom values
# under this path are ignored by gnome-terminal.
enabled=true
next-tab='{{ gnome_terminal_tab_switch_next }}'
prev-tab='{{ gnome_terminal_tab_switch_prev }}'
{% endif %}
{% if gnome_terminal_tab_switch_apply_ptyxis %}

# Ptyxis shortcuts live under the Shortcuts subschema
# (schema: org.gnome.Ptyxis.Shortcuts).
[org/gnome/Ptyxis/Shortcuts]
move-next-tab='{{ gnome_terminal_tab_switch_next }}'
move-previous-tab='{{ gnome_terminal_tab_switch_prev }}'
{% endif %}
