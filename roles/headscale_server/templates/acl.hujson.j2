{
  // Default permissive policy: every user can reach every node.
  // Tighten as needed -- see https://tailscale.com/kb/1018/acls/
  "acls": [
    { "action": "accept", "src": ["*"], "dst": ["*:*"] }
  ]{% if headscale_acl_enable_ssh | bool %},

  // Tailscale SSH between tailnet hosts. Combined with `tailscale up --ssh`
  // on each client, this replaces per-host SSH key management with ACL-based
  // auth. Note: ACL v2 rejects "*" for ssh src/dst -- use autogroups instead.
  "ssh": [
    {
      "action": "accept",
      "src": {{ headscale_acl_ssh_src | to_json }},
      "dst": {{ headscale_acl_ssh_dst | to_json }},
      "users": {{ headscale_acl_ssh_users | to_json }}
    }
  ]
{% endif %}

}
