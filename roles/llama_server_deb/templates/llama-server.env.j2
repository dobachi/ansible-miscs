# /etc/default/llama-server
# Managed by Ansible role llama_server_deb. Do not edit by hand.
#
# llama-server.service が EnvironmentFile= でこの内容を読み込む。
# 設定可能な変数の一覧は `llama-server --help` を参照。

LLAMA_ARG_HOST={{ llama_server_deb_host }}
LLAMA_ARG_PORT={{ llama_server_deb_port }}
LLAMA_ARG_CTX_SIZE={{ llama_server_deb_ctx_size }}
LLAMA_ARG_N_GPU_LAYERS={{ llama_server_deb_n_gpu_layers }}
LLAMA_ARG_ALIAS={{ llama_server_deb_model_alias }}
{% if llama_server_deb_jinja %}
LLAMA_ARG_JINJA=1
{% endif %}
{% if llama_server_deb_model_path | length > 0 %}
LLAMA_ARG_MODEL={{ llama_server_deb_model_path }}
{% else %}
LLAMA_ARG_HF_REPO={{ llama_server_deb_hf_repo }}
{% if llama_server_deb_hf_file | length > 0 %}
LLAMA_ARG_HF_FILE={{ llama_server_deb_hf_file }}
{% endif %}
{% endif %}
{% for k, v in llama_server_deb_extra_env.items() %}
{{ k }}={{ v }}
{% endfor %}
