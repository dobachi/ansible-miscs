[Desktop Entry]
# {{ ansible_managed }}
Name=Godot Engine
GenericName=Game Engine
Comment=Godot Engine {{ godot_version }}
Exec=/home/{{ ansible_facts['env']['SUDO_USER'] }}/.local/bin/godot %f
Path={{ godot_version_dir }}
Icon=godot
Terminal=false
Type=Application
Categories=Development;IDE;
MimeType=application/x-godot-project;
